{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MapRender": {
    "TileUrl": "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
    "DarkTileUrl": "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png",
    "TileCachePath": "./tile-cache",
    "TileCacheTtlDays": 30,
    "EnableTileCache": true,
    "InternalBaseUrl": "http://localhost:5000",
    "Width": 900,
    "Height": 600,
    "ShowTrack": true,
    "ShowMarkers": true,
    "ShowLabels": true,
    "AutoFit": true,
    "Padding": 80,
    "MapTheme": "light"
  }
}
